<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppEventos.Views.ResumoEventoPage"
             NavigationPage.HasNavigationBar="False"
             Title="ResumoEventoPage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label
                Text="Resumo do Evento"
                FontSize="28"
                HorizontalOptions="Center"/>

            <Label
                Text="{Binding NomeEvento}"
                FontAttributes="Bold"
                FontSize="22"/>

            <Label
                Text="{Binding LocalEvento,
                StringFormat='Local: {0}'}"/>

            <Label
                Text="{Binding DataInicio,
                StringFormat='Início: {0:dd/MM/yyyy}'}"/>

            <Label
                Text="{Binding DataTermino,
                StringFormat='Término: {0:dd/MM/yyyy}'}"/>

            <Label
                Text="{Binding NumeroParticipantes,
                StringFormat='Participantes: {0}'}"/>

            <Label
                Text="{Binding CustoPorParticipante,
                StringFormat='Custo por participante: R$ {0:F2}'}"/>

            <Label
                Text="{Binding DuracaoEvento.Days,
                StringFormat='Duração do evento: {0} dias'}"/>

            <Label
                FontAttributes="Bold"
                FontSize="20"
                Text="{Binding CustoTotal,
                StringFormat='Custo Total: R$ {0:F2}'}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>