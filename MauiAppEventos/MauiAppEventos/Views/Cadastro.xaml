<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppEventos.Views.Cadastro"
             NavigationPage.HasNavigationBar="False"
             Title="CadastroDeEventos">
    <ScrollView>
        <VerticalStackLayout VerticalOptions="CenterAndExpand" Padding="20" Spacing="15">

            <Label
                Text="Cadastro de Evento"
                FontSize="28"
                HorizontalOptions="Center"/>

            <Entry
                Placeholder="Nome do evento"
                Text="{Binding NomeEvento}" />

            <DatePicker
                Date="{Binding DataInicio}" />

            <DatePicker
                Date="{Binding DataTermino}" />

            <Entry
                Placeholder="Número de participantes"
                Keyboard="Numeric"
                Text="{Binding NumeroParticipantes}" />

            <Entry
                Placeholder="Local do evento"
                Text="{Binding LocalEvento}" />

            <Entry
                Placeholder="Custo por participante"
                Keyboard="Numeric"
                Text="{Binding CustoPorParticipante}" />

            <Button
                Text="Finalizar Cadastro"
                Clicked="Button_Clicked"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>